{
  "name": "playwright-enterprise-framework",
  "version": "1.0.0",
  "private": true,
  "description": "Pragmatic enterprise Playwright framework - generic data-driven testing, no per-file boilerplate.",
  "scripts": {
    "test": "node scripts/run-tests.js",
    "test:local": "cross-env ENV=local node scripts/run-tests.js",
    "test:qa": "cross-env ENV=qa node scripts/run-tests.js",
    "test:staging": "cross-env ENV=staging node scripts/run-tests.js",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:smoke": "playwright test --project=smoke",
    "test:regression": "playwright test --project=regression",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "typecheck": "tsc --noEmit",
    "install:browsers": "playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.14.0",
    "allure-commandline": "^2.30.0",
    "allure-playwright": "^3.0.0",
    "cross-env": "^7.0.3",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "typescript": "^5.5.4",
    "zod": "^3.23.8"
  }
}
