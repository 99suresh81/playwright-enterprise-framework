{
  "name": "playwright-enterprise-framework",
  "version": "1.0.0",
  "private": true,
  "description": "Pragmatic enterprise Playwright framework - generic data-driven testing, no per-file boilerplate.",
  "scripts": {
    "test": "playwright test --config=playwright.ui.config.ts --project=chromium --project=firefox",
    "test:local": "cross-env ENV=local playwright test --config=playwright.ui.config.ts --project=chromium --project=firefox",
    "test:qa": "cross-env ENV=qa playwright test --config=playwright.ui.config.ts --project=chromium --project=firefox",
    "test:staging": "cross-env ENV=staging playwright test --config=playwright.ui.config.ts --project=chromium --project=firefox",
    "test:headed": "playwright test --config=playwright.ui.config.ts --project=chromium --headed",
    "test:debug": "playwright test --config=playwright.ui.config.ts --project=chromium --debug",
    "test:smoke": "playwright test --config=playwright.ui.config.ts --project=smoke",
    "test:regression": "playwright test --config=playwright.ui.config.ts --project=regression",
    "test:api": "playwright test --config=playwright.api.config.ts",
    "test:api:local": "cross-env ENV=local playwright test --config=playwright.api.config.ts",
    "test:api:qa": "cross-env ENV=qa playwright test --config=playwright.api.config.ts",
    "report": "playwright show-report",
    "allure:open": "allure open allure-report",
    "allure:open:api": "allure open allure-report-api",
    "typecheck": "tsc --noEmit",
    "install:browsers": "playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.14.0",
    "allure-commandline": "^2.30.0",
    "allure-playwright": "^3.0.0",
    "cross-env": "^7.0.3",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "typescript": "^5.5.4",
    "zod": "^3.23.8"
  }
}
